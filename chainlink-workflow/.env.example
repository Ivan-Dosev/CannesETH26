# ── Chainlink CRE ────────────────────────────────────────────────
# The resolver wallet private key (this address must be set as chainlinkResolver in the contract)
RESOLVER_PRIVATE_KEY=0x...

# ── Contract ──────────────────────────────────────────────────────
CONTRACT_ADDRESS=0x...
ARC_RPC_URL=https://rpc.arc.network
ARC_CHAIN_ID=1234

# ── 0G Storage (to download market metadata) ─────────────────────
ZG_STORAGE_NODE_URL=https://storage-node.0g.ai

# ── Polling ───────────────────────────────────────────────────────
POLL_INTERVAL_MS=60000
